{
  "version": 2,
  "rewrites": [
    { "source": "/agentes", "destination": "./public/pages/agentes.html" },
    { "source": "/login", "destination": "./public/pages/login.html" },
    { "source": "/enviar", "destination": "./public/pages/enviar-look.html" },
    { "source": "/", "destination": "./public/pages/index.html" }
  ],
  "headers": [
    {
      "source": "./api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET,POST,PATCH,OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type,Authorization"
        }
      ]
    },
    {
      "source": "./public/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" },
        { "key": "Content-Type", "value": "application/javascript" }
      ]
    }
  ]
}
