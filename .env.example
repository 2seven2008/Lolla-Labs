# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://usuario:senha@cluster.mongodb.net/
MONGODB_DB=lolla-labs

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=troque-por-uma-string-longa-e-aleatoria
JWT_EXPIRES=8h

# ─── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Seed (proteção do endpoint /api/seed-agent) ──────────────────────────────
# Acesse: GET /api/seed-agent?secret=VALOR_AQUI
# Após criar o agente, pode remover esta variável ou deletar o arquivo seed-agent.js
SEED_SECRET=troque-por-um-segredo-aqui
