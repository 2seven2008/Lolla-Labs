# ─── MongoDB Atlas ────────────────────────────────────────
# Crie um cluster gratuito em https://www.mongodb.com/atlas
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=lolla-labs

# ─── Cloudinary ───────────────────────────────────────────
# Crie uma conta gratuita em https://cloudinary.com
CLOUDINARY_CLOUD_NAME=seu_cloud_name
CLOUDINARY_API_KEY=sua_api_key
CLOUDINARY_API_SECRET=seu_api_secret

# ─── JWT ──────────────────────────────────────────────────
# Gere uma string aleatória forte (ex: openssl rand -hex 32)
JWT_SECRET=troque-por-uma-string-secreta-forte-aqui
JWT_EXPIRES=8h

# ─── Agentes (opcional) ───────────────────────────────────
# Para adicionar agentes customizados, gere hashes bcrypt:
# node -e "const b=require('bcryptjs'); console.log(b.hashSync('sua_senha', 10))"
# Depois monte o JSON abaixo:
# AGENTS_JSON=[{"email":"agente@lollalabs.com","hash":"$2a$10$...","name":"Nome Agente","role":"agent"}]
#
# Se não definir, o sistema usa o agente demo:
# email: agente@lollalabs.com  |  senha: lolla2025
